{
  "name": "scalechat-desktop",
  "version": "0.1.0",
  "description": "Conector de escritorio de Scalechat: conecta WhatsApp por QR (Baileys) desde tu PC — sin proxy — y responde con tus flujos de Scalechat.",
  "main": "main.js",
  "author": "Scale SAC",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "6.7.23",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "app.scalechat.desktop",
    "productName": "Scalechat Desktop",
    "files": ["**/*", "!**/sessions/**"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg", "category": "public.app-category.business" },
    "linux": { "target": "AppImage" }
  }
}
